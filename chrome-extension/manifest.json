{
  "name": "WebLens",
  "description": "See beyond the page.",
  "version": "1.1",
  "manifest_version": 3,
  "permissions": ["activeTab", "scripting", "storage", "sidePanel"],
  "host_permissions": ["http://127.0.0.1:8000/*", "http://*/*", "https://*/*"],
  "action": {
    "default_title": "Open WebLens"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  }
}
